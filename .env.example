# THE SYSTEM — website / APK download host.
# Copy to .env and fill in; docker-compose.yml reads these.

# Host port the site is served on.
WEBSITE_PORT=8080

# Shared secret for the authenticated APK upload endpoint (/deploy/the-system.apk).
# The release CI presents it as `Authorization: Bearer <token>` (repo secret DEPLOY_TOKEN).
# Generate a strong random value:  openssl rand -hex 32
DEPLOY_TOKEN=change-me
